# Copy to .env and fill in. Never commit real values.

# Google Maps (route→image download)
GOOGLE_MAPS_API_KEY=

# Postgres/PostGIS (docker compose up -d db)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/smooth_route

# --- Auth (Clerk) ---
# "clerk" verifies Bearer JWTs; "disabled" = local single-user mode (everything
# runs as admin — development only, never in production).
AUTH_MODE=clerk
# Secret key from https://dashboard.clerk.com → API Keys (sk_test_... in dev).
# Used for backend→Clerk API calls (e.g. email lookup at first login).
CLERK_SECRET_KEY=
# Issuer of the Clerk instance, e.g. https://your-app.clerk.accounts.dev
# (JWKS is derived as {CLERK_ISSUER}/.well-known/jwks.json)
CLERK_ISSUER=
# Origins accepted in the token azp claim (comma-separated).
CLERK_AUTHORIZED_PARTIES=http://localhost:5173
