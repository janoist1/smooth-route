# Clerk publishable key (pk_test_... for the dev instance).
# Get it from https://dashboard.clerk.com → API Keys.
# Leave empty to run the frontend in anonymous mode (no sign-in UI).
# Round-1 public deploy: leave EMPTY (anonymous read-only).
VITE_CLERK_PUBLISHABLE_KEY=

# Read-API origin. Empty in dev → relative "/graphql" (Vite proxy to :8000).
# Round-1 prod (two Vercel projects): set to the API deploy, e.g.
# VITE_API_URL=https://api.simaut.hu
VITE_API_URL=
